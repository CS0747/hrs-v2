# Production Environment Configuration
# This file is used when building for production

# Base URL for the application
VITE_BASE_URL=/hrsystem/

# API Base URL - adjust this to your production server IP/hostname
# Example for LAN: http://192.168.1.100/hrsystem/server/api/
# Example for localhost: http://localhost/hrsystem/server/api/
VITE_API_BASE_URL=/hrsystem/server/api/
